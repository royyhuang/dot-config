@techreport{Doudou99Muteness,
	Abstract = {This paper extends the failures detector approach from
                 crash-stop failures to muteness failures. Muteness
                 failures are malicious failures in which a process stops
                 sending algorithm messages, but might continue to send
                 other messages, e.g. 'I-am-alive' messages. The paper
                 presents both the specification of a muteness failure
                 detector, denoted by MA, and an implementation of MA in a
                 partial synchrony model (there are bounds on message
                 latency and clock skew, but these bounds are unknown and
                 hold only after some point that is itself unknown). We
                 show that, modulo a simple modification, a consensus
                 algorithm that has been designed in a crash-stop model
                 with S, can be reused in the presence of muteness
                 failures simply by replacing MA with S.},
	Affiliation = {EPFL},
	Author = {Doudou, A. and Garbinato, B. and Guerraoui, R. and Schiper, A.},
	Date-Added = {2010-08-09 22:00:23 -0500},
	Date-Modified = {2010-08-09 22:00:23 -0500},
	Details = {http://infoscience.epfl.ch/record/52304},
	Documenturl = {http://infoscience.epfl.ch/getfile.py?recid=52304},
	Oai-Id = {oai:infoscience.epfl.ch:52304},
	Oai-Set = {fulltext; report; fulltext-public},
	Status = {PUBLISHED},
	Title = {Muteness {F}ailure {D}etectors, {S}pecification and {I}mplementation},
	Unit = {LSR},
	Year = 1999}

