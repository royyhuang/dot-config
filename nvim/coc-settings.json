{
	"texlab.latexindent.modifyLineBreaks": true,
	"explorer.icon.enableNerdfont": true,
	"explorer.icon.source": "nvim-web-devicons",
	"explorer.enableFloatinput": true,
	"Lua.workspace.preloadFileSize": 1500,
	"coc.source.file.enable": false,
	"coc.source.buffer.enable": false,
	"coc.source.around.enable": false,
	"sumneko-lua.enableNvimLuaDev": true,
	"coc.preferences.extensionUpdateCheck": "daily",
	"texlab.build.onSave": true,
	"texlab.build.args": [
		"-pdf",
		"-interaction=nonstopmode",
		"-synctex=1",
		"-pvc",
		"%f"
	]
}

